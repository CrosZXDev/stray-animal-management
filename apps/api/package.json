    "@nestjs/cli": "^10.3.0",
    "@nestjs/testing": "^10.3.0",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.6",
    "@types/nodemailer": "^6.4.24",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "fast-check": "^3.19.0",
    "prisma": "^5.15.0",
    "supertest": "^7.0.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
