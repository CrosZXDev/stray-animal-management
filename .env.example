# Database
DATABASE_URL=postgresql://stray_admin:stray_dev_password@localhost:5432/stray_animal?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d

# LINE OA
LINE_CHANNEL_ID=your-line-channel-id
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_ACCESS_TOKEN=your-line-access-token
LINE_CALLBACK_URL=http://localhost:3001/api/v1/auth/line/callback

# AWS
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=stray-animal-images
AWS_CLOUDFRONT_URL=https://cdn.example.com
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret

# App
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
NODE_ENV=development
PORT=3001

# Email (SMTP — optional, disabled by default)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_ADDRESS=noreply@stray-animal.local
SMTP_FROM_NAME=ระบบจัดการสัตว์จรจัด
